# Canopy Environment Configuration
# Copy this file to .env and fill in your local values

# MongoDB
MONGODB_URI=mongodb://localhost:27017/canopy

# Server
PORT=5000
NODE_ENV=development
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ML Service
ML_SERVICE_URL=http://localhost:8000

# Redis
REDIS_URL=redis://localhost:6379

# Email (Nodemailer / Mailtrap dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM=canopy@example.com

# Twilio (SMS/WhatsApp sandbox)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Client (Vite proxy target)
VITE_API_URL=http://localhost:5000/api
VITE_ML_SERVICE_URL=http://localhost:8000
